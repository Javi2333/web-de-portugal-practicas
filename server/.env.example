# ── Stripe ──────────────────────────────────────────────────────────
# Clave secreta de Stripe → https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=poner_aqui_tu_clave_secreta_de_stripe

# Secreto del webhook de Stripe → se genera al crear el webhook en el dashboard
# Endpoint a configurar en Stripe: https://TU_DOMINIO/webhook
STRIPE_WEBHOOK_SECRET=whsec_XXXXXXXXXXXXXXXXXXXXXXXX

# ── Supabase ─────────────────────────────────────────────────────────
# Clave SERVICE ROLE (no la anon) → Supabase > Settings > API > service_role
# ¡Nunca la expongas en el frontend! Solo va aquí en el servidor.
SUPABASE_SERVICE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.XXXXXXXX

# ── Email (Resend) ───────────────────────────────────────────────────
# API key de Resend → https://resend.com → "API Keys"
# Plan gratuito: 100 emails/día sin límite de tiempo
RESEND_API_KEY=re_XXXXXXXXXXXXXXXXXXXXXXXX

# Remitente del email de seguimiento
# Durante pruebas puedes usar: onboarding@resend.dev
# En producción usa tu propio dominio verificado en Resend: noreply@tudominio.com
EMAIL_FROM=Letreros Programables <onboarding@resend.dev>

# ── Servidor ─────────────────────────────────────────────────────────
# URL donde está la web (para que Stripe sepa a dónde redirigir)
FRONTEND_URL=http://localhost:3000
PORT=3000
